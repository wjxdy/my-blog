        <result column="register_time" property="registerTime" />
        <result column="img_url" property="imgUrl" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, name, sex, phone, email, username, password, register_time, img_url
    </sql>

</mapper>
